SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here

# Admin UI password
ADMIN_PASSWORD=changeme

# SQLite database file path
DATABASE_URL=sqlite+aiosqlite:///./tracker.db

# Daily auto sign-out time in 24h format (HH:MM), local time
AUTO_SIGNOUT_TIME=22:00

# "Wall of Shame" meme: post a lighthearted meme to a channel naming kids who
# forgot to sign out (closed by the nightly auto sign-out job).
# ROAST_ENABLED is the global on/off switch; off by default.
# The bot must have chat:write + files:write scopes and be invited to the channel.
ROAST_ENABLED=false
SLACK_ANNOUNCE_CHANNEL=

# Weekly DM job: day (0=Mon ... 6=Sun) and time (HH:MM), local time
WEEKLY_DM_DAY=6
WEEKLY_DM_TIME=21:00

# Nightly SQLite backup: time (HH:MM) and how many snapshots to retain
BACKUP_TIME=23:30
BACKUP_KEEP=14

# Master switch for automated Slack messages, memes, and scheduled DMs
UPDATES_ENABLED=true

# Comma-separated CIDRs allowed to submit sign-ins via the kiosk (blank = no restriction).
# Behind nginx, the real client IP is read from X-Forwarded-For via --proxy-headers.
SIGNIN_IP_WHITELIST=

# Secret key for session cookies (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET=replace-with-a-long-random-string

# Timezone, e.g. America/New_York
TIMEZONE=America/New_York
