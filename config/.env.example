# Attendance Tracker Configuration
# Copy this file to .env and fill in your values

# Flask Configuration
SECRET_KEY=your-secret-key-here-change-this-in-production
FLASK_ENV=development

# Google Sheets Configuration
GOOGLE_SHEETS_SPREADSHEET_ID=your-spreadsheet-id-here
GOOGLE_SHEETS_WORKSHEET_NAME=Attendance

# Application Settings
PORT=5000

# Optional: Google Sheets sync interval (minutes)
SYNC_INTERVAL_MINUTES=15

# Expected Hours Configuration
EXPECTED_HOURS_START_DATE=2026-01-05
EXPECTED_HOURS_END_DATE=2026-03-14
EXPECTED_HOURS_WEEKLY_INCREASE=11

# Slack Bot Configuration
# To enable Slack notifications, set SLACK_ENABLED=True and provide your bot token
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_ENABLED=False
# Day of week to send notifications (0=Monday, 6=Sunday)
SLACK_NOTIFICATION_DAY=6
# Hour of day to send notifications (24-hour format)
SLACK_NOTIFICATION_HOUR=20
